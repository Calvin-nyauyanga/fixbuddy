datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User Model
model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  password  String
  name      String
  role      String  @default("user") // "user", "agent", "admin"
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsCreated Ticket[] @relation("CreatedBy")
  ticketsAssigned Ticket[] @relation("AssignedTo")
  comments Comment[]

  @@map("users")
}

// Ticket Model
model Ticket {
  id          Int     @id @default(autoincrement())
  title       String
  description String  @db.Text
  status      String  @default("open") // "open", "in_progress", "closed", "on_hold"
  priority    String  @default("medium")  //"low", "medium", "high", "critical"
  category    String?

  createdById Int
  createdBy   User    @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  assignedToId Int?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments    Comment[]

  @@map("tickets")
}

// Comment Model
model Comment {
  id        Int     @id @default(autoincrement())
  content   String @db.Text

  ticketId  Int
  ticket    Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}